// Evidence Management System - Database Schema
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// USER MANAGEMENT
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  badgeId       String   @unique @map("badge_id")
  role          Role     @default(INVESTIGATOR)
  walletAddress String?  @unique @map("wallet_address")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  evidences       Evidence[]       @relation("EvidenceCollector")
  custodyLogsFrom CustodyLog[]     @relation("CustodyFrom")
  custodyLogsTo   CustodyLog[]     @relation("CustodyTo")
  verifications   Verification[]
  transferRequests TransferRequest[] @relation("TransferInitiator")

  @@map("users")
}

enum Role {
  ADMIN
  INVESTIGATOR
  AUDITOR
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// CASE MANAGEMENT
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Case {
  id          String     @id @default(uuid())
  caseNumber  String     @unique @map("case_number")
  title       String
  description String?    @db.Text
  status      CaseStatus @default(OPEN)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  evidences Evidence[]

  @@index([caseNumber])
  @@index([status])
  @@map("cases")
}

enum CaseStatus {
  OPEN
  CLOSED
  ARCHIVED
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// EVIDENCE RECORDS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Evidence {
  id                String         @id @default(uuid())
  evidenceId        String?        @unique @map("evidence_id") // on-chain bytes32 (hex)
  caseId            String         @map("case_id")
  title             String
  description       String?        @db.Text
  evidenceType      EvidenceType   @default(DOCUMENT) @map("evidence_type")
  fileHash          String         @unique @map("file_hash") // SHA-256 hex
  fileURI           String         @map("file_uri") // local path or IPFS CID
  fileName          String?        @map("file_name") // original filename
  fileSize          Int?           @map("file_size") // bytes
  locationText      String?        @map("location_text")
  collectedAt       DateTime       @map("collected_at")
  status            EvidenceStatus @default(COLLECTED)
  isSensitive       Boolean        @default(false) @map("is_sensitive")
  collectedById     String         @map("collected_by_id")
  currentOwnerId    String?        @map("current_owner_id") // can be null during transfer
  txHash            String?        @map("tx_hash") // blockchain transaction hash
  blockNumber       Int?           @map("block_number")
  registeredOnChain Boolean        @default(false) @map("registered_on_chain")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  // Relations
  case          Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  collectedBy   User           @relation("EvidenceCollector", fields: [collectedById], references: [id])
  custodyLogs   CustodyLog[]
  verifications Verification[]

  @@index([caseId])
  @@index([evidenceId])
  @@index([fileHash])
  @@index([status])
  @@index([collectedById])
  @@index([createdAt])
  @@map("evidences")
}

enum EvidenceType {
  DOCUMENT
  IMAGE
  VIDEO
  AUDIO
  DIGITAL
  PHYSICAL
  OTHER
}

enum EvidenceStatus {
  COLLECTED
  SUBMITTED
  UNDER_REVIEW
  TRANSFERRED
  ARCHIVED
  REJECTED
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// CHAIN OF CUSTODY
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model CustodyLog {
  id         String   @id @default(uuid())
  evidenceId String   @map("evidence_id")
  fromUserId String?  @map("from_user_id") // null for initial registration
  toUserId   String   @map("to_user_id")
  action     String   // "REGISTERED", "TRANSFERRED", "STATUS_CHANGED", etc.
  reason     String?  @db.Text
  txHash     String?  @map("tx_hash")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  evidence Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  fromUser User?    @relation("CustodyFrom", fields: [fromUserId], references: [id])
  toUser   User     @relation("CustodyTo", fields: [toUserId], references: [id])

  @@index([evidenceId])
  @@index([createdAt])
  @@map("custody_logs")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// VERIFICATION RECORDS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Verification {
  id           String   @id @default(uuid())
  evidenceId   String   @map("evidence_id")
  verifiedById String   @map("verified_by_id")
  fileHash     String   @map("file_hash") // hash of file being verified
  isAuthentic  Boolean  @map("is_authentic")
  txHash       String?  @map("tx_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  evidence   Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  verifiedBy User     @relation(fields: [verifiedById], references: [id])

  @@index([evidenceId])
  @@index([verifiedById])
  @@index([createdAt])
  @@map("verifications")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// MULTI-SIG TRANSFER REQUESTS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model TransferRequest {
  id              String   @id @default(uuid())
  requestId       String?  @unique @map("request_id") // on-chain bytes32
  evidenceId      String   @map("evidence_id")
  initiatorId     String   @map("initiator_id")
  proposedOwnerId String   @map("proposed_owner_id")
  reason          String?  @db.Text
  approvalCount   Int      @default(0) @map("approval_count")
  approvers       String[] @default([]) // array of user IDs who approved
  executed        Boolean  @default(false)
  cancelled       Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  initiator User @relation("TransferInitiator", fields: [initiatorId], references: [id])

  @@index([requestId])
  @@index([evidenceId])
  @@index([executed])
  @@index([cancelled])
  @@map("transfer_requests")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// AUDIT LOG (optional — for tracking all system actions)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id") // null for system actions
  action    String   // "USER_LOGIN", "EVIDENCE_REGISTERED", etc.
  resource  String?  // resource type: "EVIDENCE", "USER", "CASE"
  resourceId String? @map("resource_id")
  metadata  Json?    // additional context
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}